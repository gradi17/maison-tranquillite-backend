# Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
# Ne JAMAIS committer le fichier ".env" réel dans un dépôt public.

# Clé secrète Stripe (Dashboard Stripe > Développeurs > Clés API)
# Commence par "sk_test_" en mode test, "sk_live_" en production.
STRIPE_SECRET_KEY=sk_test_...

# Signature du webhook (générée quand vous créez le endpoint webhook
# dans le Dashboard Stripe, ou via `stripe listen` en local)
STRIPE_WEBHOOK_SECRET=whsec_...

# URL de votre site (utilisée pour les redirections après paiement)
FRONTEND_URL=https://votredomaine.fr

# Port du serveur (optionnel, 4000 par défaut)
PORT=4000

# Si vous envoyez les emails via Resend (voir README)
RESEND_API_KEY=
